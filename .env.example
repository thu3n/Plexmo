# Database Configuration
# Optional: Override the default database location
# CONFIG_DIR=./config

# Application Environment
# Options: development, production
NODE_ENV=development

# Security
# Secret key for JWT signing. Generate a random string for production.
JWT_SECRET=input_a_secure_random_string_here

# Plex Configuration
# Optional: Pre-configured Plex Token (usually set via UI)
# PLEX_TOKEN=

# Database URL (Fallback/Legacy)
# DATABASE_URL=file:./config/plex-monitor.db
